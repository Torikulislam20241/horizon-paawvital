{%- liquid
  assign section_width = section.settings.section_width
  assign section_bg    = section.settings.background_color
  assign heading_color = section.settings.heading_color
  assign title_color   = section.settings.title_color
  assign desc_color    = section.settings.description_color
  assign pt            = section.settings.padding_top
  assign pb            = section.settings.padding_bottom
  assign pt_m          = section.settings.padding_top_mobile
  assign pb_m          = section.settings.padding_bottom_mobile
  assign card_bg       = section.settings.card_background
  assign card_radius   = section.settings.card_border_radius
  assign card_border   = section.settings.card_border_color
  assign icon_sz       = section.settings.icon_size
  assign icon_sz_m     = section.settings.icon_size_mobile
-%}

<style>
  /* ── Section wrapper ──
     Removed the old display:flex + min-height(vh) rules. Those forced the
     section to a fixed viewport-relative height and then vertically centered
     the heading+grid inside it, which is what produced the large empty band
     above/below the cards and made this section feel disconnected from the
     sections above it. Height now comes naturally from padding + content. */
  #pv-adv-{{ section.id }} {
    background-color: {{ section_bg }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }

  #pv-adv-{{ section.id }} .pv-adv__inner {
    width: 100%;
    margin-inline: auto;
    box-sizing: border-box;

    /* Width Logic */
    {% if section_width == 'page' %}
      max-width: var(--page-width, 1250px);
      padding-inline: var(--page-margin, 24px);
    {% elsif section_width == 'full' %}
      max-width: 100%;
      padding-inline: 0;
    {% endif %}
  }

  #pv-adv-{{ section.id }} .pv-adv__heading {
    color: {{ heading_color }};
    font-family: var(--font-heading--family, var(--font-body--family, inherit));
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, {{ section.settings.heading_size }}px);
    line-height: 1.2;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    letter-spacing: -0.01em;
  }

  #pv-adv-{{ section.id }} .pv-adv__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  #pv-adv-{{ section.id }} .pv-adv__card {
    background-color: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: {{ card_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  #pv-adv-{{ section.id }} .pv-adv__card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
    transform: translateY(-2px);
  }

  #pv-adv-{{ section.id }} .pv-adv__icon-wrap {
    width: {{ icon_sz }}px;
    height: {{ icon_sz }}px;
    margin-bottom: {{ section.settings.icon_margin_bottom }}px;
    flex-shrink: 0;
  }

  #pv-adv-{{ section.id }} .pv-adv__icon-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #pv-adv-{{ section.id }} .pv-adv__card-title {
    color: {{ title_color }};
    font-family: var(--font-heading--family, var(--font-body--family, inherit));
    font-weight: 700;
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.3;
    margin: 0 0 {{ section.settings.title_margin_bottom }}px;
  }

  #pv-adv-{{ section.id }} .pv-adv__card-desc {
    color: {{ desc_color }};
    font-family: var(--font-body--family, inherit);
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Desktop (≥990px): 4-across grid ──
     4 cards in a single row reads as a premium, full-width band that
     matches the wider grids used in the sections above. ── */
  @media screen and (min-width: 990px) {
    #pv-adv-{{ section.id }} .pv-adv__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Large desktop / 24" monitors (≥1600px) ── */
  @media screen and (min-width: 1600px) {
    #pv-adv-{{ section.id }} .pv-adv__inner {
      max-width: 1400px;
    }

    #pv-adv-{{ section.id }} .pv-adv__heading {
      font-size: calc({{ section.settings.heading_size }}px + 8px);
    }

    #pv-adv-{{ section.id }} .pv-adv__card-title {
      font-size: calc({{ section.settings.title_size }}px + 2px);
    }

    #pv-adv-{{ section.id }} .pv-adv__card-desc {
      font-size: calc({{ section.settings.description_size }}px + 1px);
    }
  }

  /* ── Tablet (750px–989px): 2 columns ── */
  @media screen and (max-width: 989px) and (min-width: 750px) {
    #pv-adv-{{ section.id }} .pv-adv__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    #pv-adv-{{ section.id }} {
      padding-top: {{ pt_m }}px;
      padding-bottom: {{ pb_m }}px;
    }

    #pv-adv-{{ section.id }} .pv-adv__inner {
      {% if section_width == 'page' %}
        padding-inline: var(--page-margin, 16px);
      {% endif %}
    }

    #pv-adv-{{ section.id }} .pv-adv__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: {{ section.settings.heading_margin_bottom_mobile }}px;
    }

    #pv-adv-{{ section.id }} .pv-adv__grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.card_gap_mobile }}px;
    }

    #pv-adv-{{ section.id }} .pv-adv__card {
      padding: {{ section.settings.card_padding_mobile }}px;
      width: 100%;
      box-sizing: border-box;
    }

    #pv-adv-{{ section.id }} .pv-adv__icon-wrap {
      width: {{ icon_sz_m }}px;
      height: {{ icon_sz_m }}px;
      margin-bottom: {{ section.settings.icon_margin_bottom_mobile }}px;
    }

    #pv-adv-{{ section.id }} .pv-adv__card-title {
      font-size: {{ section.settings.title_size_mobile }}px;
      margin-bottom: {{ section.settings.title_margin_bottom_mobile }}px;
    }

    #pv-adv-{{ section.id }} .pv-adv__card-desc {
      font-size: {{ section.settings.description_size_mobile }}px;
    }
  }
</style>

<section
  id="pv-adv-{{ section.id }}"
  class="pv-advantages-grid"
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="pv-adv__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="pv-adv__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="pv-adv__grid">
      {%- for i in (1..4) -%}
        {%- liquid
          assign key_enabled = 'card_' | append: i | append: '_enabled'
          assign key_icon    = 'card_' | append: i | append: '_icon'
          assign key_title   = 'card_' | append: i | append: '_title'
          assign key_desc    = 'card_' | append: i | append: '_description'
        -%}

        {%- if section.settings[key_enabled] -%}
          <article class="pv-adv__card">

            {%- if section.settings[key_icon] != blank -%}
              <div class="pv-adv__icon-wrap">
                {{-
                  section.settings[key_icon]
                  | image_url: width: 128
                  | image_tag:
                    loading: 'lazy',
                    width: section.settings.icon_size,
                    height: section.settings.icon_size,
                    alt: section.settings[key_title] | escape
                -}}
              </div>
            {%- endif -%}

            {%- if section.settings[key_title] != blank -%}
              <h3 class="pv-adv__card-title">{{ section.settings[key_title] | escape }}</h3>
            {%- endif -%}

            {%- if section.settings[key_desc] != blank -%}
              <p class="pv-adv__card-desc">{{ section.settings[key_desc] }}</p>
            {%- endif -%}

          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

