<section class="pv-section pv-steps">
  <div class="pv-steps__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="pv-steps__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="pv-steps__grid">
      {%- for i in (1..3) -%}
        {%- liquid
          assign img_key   = 'image_' | append: i
          assign vid_key   = 'video_' | append: i
          assign title_key = 'title_' | append: i
          assign text_key  = 'text_'  | append: i

          assign step_img  = section.settings[img_key]
          assign step_vid  = section.settings[vid_key]
          assign step_title= section.settings[title_key]
          assign step_text = section.settings[text_key]
        -%}
        <div class="pv-steps__item">
          <div class="pv-steps__media">
            {%- if step_vid != blank -%}
              {{ step_vid | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'pv-steps__video' }}
            {%- elsif step_img != blank -%}
              <img
                src="{{ step_img | image_url: width: 700 }}"
                alt="{{ step_img.alt | escape }}"
                width="700" height="525"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-' | append: i | placeholder_svg_tag: 'pv-placeholder-svg' }}
            {%- endif -%}
          </div>

          <span class="pv-steps__num">STEP {{ i }}</span>
          {%- if step_title != blank -%}<h3 class="pv-steps__title">{{ step_title }}</h3>{%- endif -%}
          {%- if step_text  != blank -%}<p  class="pv-steps__text">{{ step_text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
 <style>
  /* ── Section wrapper ── */
  .pv-section.pv-steps {
    margin-top: 80px;
    padding: 0 40px 90px;
    font-family: Inter, sans-serif;
  }

  /* ── Heading ── */
  .pv-steps__heading {
    text-align: center;
    font-family: Inter, sans-serif;
    font-weight: 700;
    font-size: 46px;
    color: #000000;
    margin-bottom: 56px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  /* ── 3-column grid (desktop) ── */
  .pv-steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px;
    max-width: 1250px;
    margin: 0 auto;
  }

  /* ── Each card ── */
  .pv-steps__item {
    text-align: center;
    background: #ffffffff;
    border-radius: 16px;
    padding: 44px 28px;
  }

  /* ── Media box (Image or Video) ── */
  /* Increased height so the video reads as the focal point of the card,
     rather than the surrounding background. */
  .pv-steps__media {
    width: 100%;
    height: 480px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 28px;
    border-radius: 12px;
    overflow: hidden;
    background-color: #e5e5e5;
  }

  .pv-steps__media video,
  .pv-steps__media img,
  .pv-steps__media .pv-placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px;
  }

  /* ── Step label ── */
  .pv-steps__num {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #00cea7;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  /* ── Step title ── */
  .pv-steps__title {
    font-family: Inter, sans-serif;
    font-weight: 700;
    font-size: 24px;
    color: #000000;
    margin: 0 0 14px;
  }

  /* ── Step text ── */
  .pv-steps__text {
    font-family: Inter, sans-serif;
    font-weight: 400;
    font-size: 17px;
    color: #000000cf;
    margin: 0;
    line-height: 1.7;
  }

  /* ── Large desktop / 24" monitors (≥1600px) ── */
  @media (min-width: 1600px) {
    .pv-section.pv-steps {
      padding: 0 60px 110px;
    }

    .pv-steps__heading {
      font-size: 52px;
      margin-bottom: 64px;
    }

    .pv-steps__grid {
      max-width: 1400px;
      gap: 40px;
    }

    .pv-steps__item {
      padding: 48px 32px;
    }

    .pv-steps__media {
      height: 540px;
      margin-bottom: 32px;
    }

    .pv-steps__title {
      font-size: 26px;
    }

    .pv-steps__text {
      font-size: 18px;
    }
  }

  /* ── Tablet (2 columns) ── */
  @media (max-width: 989px) {
    .pv-section.pv-steps {
      padding: 0 24px 64px;
    }

    .pv-steps__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .pv-steps__heading {
      font-size: 36px;
      margin-bottom: 40px;
    }

    .pv-steps__media {
      height: 420px;
    }
  }

  /* ── Mobile (1 column) ── */
  @media (max-width: 749px) {
    .pv-section.pv-steps {
      margin-top: 50px;
      padding: 0 16px 50px;
    }

    .pv-steps__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .pv-steps__heading {
      font-size: 30px;
      margin-bottom: 28px;
    }

    .pv-steps__item {
      padding: 36px 22px;
    }

    .pv-steps__media {
      height: 400px;
      margin-bottom: 20px;
    }

    .pv-steps__title {
      font-size: 21px;
    }

    .pv-steps__text {
      font-size: 16px;
    }
  }
 </style>
</section>

{% schema %}
{
  "name": "PV Steps",
  "tag": "div",
  "class": "pv-section",
  "settings": [
    {"type": "text", "id": "heading", "label": "Section Heading", "default": "Why Pet Owners Love Our Product"},

    {"type": "header", "content": "Step 1"},
    {"type": "video", "id": "video_1", "label": "Step 1 Video (Vertical/Mobile Size)"},
    {"type": "image_picker", "id": "image_1", "label": "Step 1 Image (Fallback)"},
    {"type": "text", "id": "title_1", "label": "Step 1 Title", "default": "Drag Across the Surface"},
    {"type": "textarea", "id": "text_1", "label": "Step 1 Text", "default": "Simply glide across any fabric in one direction to start attracting pet hair."},

    {"type": "header", "content": "Step 2"},
    {"type": "video", "id": "video_2", "label": "Step 2 Video (Vertical/Mobile Size)"},
    {"type": "image_picker", "id": "image_2", "label": "Step 2 Image (Fallback)"},
    {"type": "text", "id": "title_2", "label": "Step 2 Title", "default": "Collect Hair Effortlessly"},
    {"type": "textarea", "id": "text_2", "label": "Step 2 Text", "default": "Static charge grabs and collects pet hair without any sticky residue or chemicals."},

    {"type": "header", "content": "Step 3"},
    {"type": "video", "id": "video_3", "label": "Step 3 Video (Vertical/Mobile Size)"},
    {"type": "image_picker", "id": "image_3", "label": "Step 3 Image (Fallback)"},
    {"type": "text", "id": "title_3", "label": "Step 3 Title", "default": "Rinse and Reuse"},
    {"type": "textarea", "id": "text_3", "label": "Step 3 Text", "default": "Wash off the collected hair under water and it is ready to use again instantly."}
  ],
  "presets": [{"name": "PV Steps"}]
}
{% endschema %}