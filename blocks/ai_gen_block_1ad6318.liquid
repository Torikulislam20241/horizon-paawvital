{% doc %}
  @prompt
    faq question make, it will be responsive and follow my store layout and size also the section layout size, I want to make it perfect like this. There will be dividers and alignment will be correct please.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-faq-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-faq-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    {% if block.settings.show_container_border %}
      border: {{ block.settings.container_border_width }}px solid {{ block.settings.container_border_color }};
      border-radius: {{ block.settings.container_border_radius }}px;
      overflow: hidden;
    {% endif %}
  }

  .ai-faq-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.item_background_color }};
    {% unless block.settings.show_container_border %}
      border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
      border-radius: {{ block.settings.item_border_radius }}px;
      margin-bottom: {{ block.settings.spacing_between_items }}px;
      overflow: hidden;
    {% endunless %}
  }

  {% if block.settings.show_container_border %}
    .ai-faq-item-{{ ai_gen_id }} + .ai-faq-item-{{ ai_gen_id }} {
      border-top: {{ block.settings.divider_width }}px solid {{ block.settings.divider_color }};
    }
  {% else %}
    .ai-faq-item-{{ ai_gen_id }}:last-child {
      margin-bottom: 0;
    }
  {% endif %}

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.item_padding }}px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    font-size: {{ block.settings.question_size }}px;
    font-weight: {{ block.settings.question_weight }};
    color: {{ block.settings.question_color }};
    transition: background-color 0.2s ease;
    line-height: 1.4;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.item_hover_background }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    transition: transform 0.3s ease;
    color: {{ block.settings.icon_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0 {{ block.settings.item_padding }}px;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
    padding: 0 {{ block.settings.item_padding }}px {{ block.settings.item_padding }}px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
    padding-top: {{ block.settings.answer_top_spacing }}px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} ul,
  .ai-faq-answer-content-{{ ai_gen_id }} ol {
    margin: 0 0 12px 0;
    padding-left: 20px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} ul:last-child,
  .ai-faq-answer-content-{{ ai_gen_id }} ol:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.75);
    }

    .ai-faq-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-faq-question-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_size }}px * 0.9);
      padding: {{ block.settings.item_padding | times: 0.75 }}px;
      gap: 12px;
    }

    .ai-faq-answer-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.item_padding | times: 0.75 }}px;
    }

    .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.item_padding | times: 0.75 }}px {{ block.settings.item_padding | times: 0.75 }}px;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_size }}px * 0.9);
    }

    .ai-faq-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      height: calc({{ block.settings.icon_size }}px * 0.85);
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.description != blank %}
    <div class="ai-faq-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-faq-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-faq-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>
  {% endif %}

  <ul class="ai-faq-list-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign question_key = 'question_' | append: i
        assign answer_key = 'answer_' | append: i
        assign question = block.settings[question_key]
        assign answer = block.settings[answer_key]
      %}

      {% if question != blank %}
        <li class="ai-faq-item-{{ ai_gen_id }} {% if forloop.first and block.settings.first_item_open %}active{% endif %}" data-faq-item>
          <button
            class="ai-faq-question-{{ ai_gen_id }}"
            aria-expanded="{% if forloop.first and block.settings.first_item_open %}true{% else %}false{% endif %}"
            data-faq-button
          >
            <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
            <svg class="ai-faq-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="ai-faq-answer-{{ ai_gen_id }}" data-faq-answer>
            <div class="ai-faq-answer-content-{{ ai_gen_id }}">
              {% if answer != blank %}
                {{ answer }}
              {% else %}
                <p>Add an answer for this question in the block settings.</p>
              {% endif %}
            </div>
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('[data-faq-button]');
          
          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              this.closeItem(item);
            } else {
              this.items.forEach((otherItem) => {
                if (otherItem !== item) {
                  this.closeItem(otherItem);
                }
              });
              this.openItem(item);
            }
          });
        });
      }

      openItem(item) {
        const button = item.querySelector('[data-faq-button]');
        item.classList.add('active');
        button.setAttribute('aria-expanded', 'true');
      }

      closeItem(item) {
        const button = item.querySelector('[data-faq-button]');
        item.classList.remove('active');
        button.setAttribute('aria-expanded', 'false');
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

