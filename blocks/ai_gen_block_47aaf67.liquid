{% doc %}
  @prompt
    Create a custom Shopify theme section called "Advantages / Features Grid" with the following layout and behavior:
    
    **Desktop layout:**
    - A heading at the top left (e.g. "Advantages of Wuff & Co")
    - Below it, a 2-column grid of 4 feature cards
    - Each card has: a small icon image (uploadable), a bold title, and a short paragraph description
    - Clean white/off-white background, minimal styling, navy/dark text for titles
    
    **Mobile layout:**
    - Stack all 4 cards vertically in a single column scroll format (no horizontal scroll)
    - Cards should be full-width on mobile
    
    **Content (pre-fill as defaults, all editable in theme editor):**
    1. Icon + Title: "Removes 99% of impurities" + Description: "The 5-layer carbon filter removes magnesium, calcium, hair, dirt, and other impurities from your dog's water."
    2. Icon + Title: "30-day guarantee" + Description: "Whether in 30 minutes or after 30 days – if you are not satisfied as a customer, you will receive your money back, no questions asked."
    3. Icon + Title: "Veterinarian tested & recommended" + Description: "Our products have been tested, approved, and recommended by veterinarians."
    4. Icon + Title: "100% dog-safe materials" + Description: "All our products are food-safe and comply with FDA regulations."
    
    **Settings (editable in theme editor):**
    - Section heading text
    - Each card: icon image picker, title text, description text
    - Option to add more cards (up to 6)
    
    Make the section fully responsive with clean CSS, no dependencies on external libraries.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-features-grid-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-features-grid-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    padding-left: {{ block.settings.card_padding }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-features-grid-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-features-grid-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-features-grid-icon-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.icon_margin_bottom }}px;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-features-grid-icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-features-grid-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-features-grid-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-features-grid-card-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    line-height: 1.3;
  }

  .ai-features-grid-card-description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-features-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-features-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin: 0 0 {{ block.settings.heading_margin_bottom }}px {{ block.settings.card_padding }}px;
      padding-left: 0;

    }

    .ai-features-grid-cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-features-grid-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_mobile }}px;
    }

    .ai-features-grid-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
      margin-bottom: {{ block.settings.icon_margin_bottom_mobile }}px;
    }

    .ai-features-grid-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
      margin-bottom: {{ block.settings.title_margin_bottom_mobile }}px;
    }

    .ai-features-grid-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-features-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-features-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-features-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-features-grid-cards-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_icon_key = 'card_' | append: i | append: '_icon'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_description_key = 'card_' | append: i | append: '_description'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_icon = block.settings[card_icon_key]
          assign card_title = block.settings[card_title_key]
          assign card_description = block.settings[card_description_key]
        %}

        {% if card_enabled %}
          <div class="ai-features-grid-card-{{ ai_gen_id }}">
            <div class="ai-features-grid-icon-wrapper-{{ ai_gen_id }}">
              {% if card_icon %}
                <img
                  src="{{ card_icon | image_url: width: 200 }}"
                  alt="{{ card_title | escape }}"
                  class="ai-features-grid-icon-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-features-grid-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if card_title != blank %}
              <h3 class="ai-features-grid-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_description != blank %}
              <p class="ai-features-grid-card-description-{{ ai_gen_id }}">{{ card_description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

